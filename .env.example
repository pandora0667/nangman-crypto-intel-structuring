INTEL_STRUCTURING_REPO_ROOT=/opt/nangman-crypto
NATS_URL=nats://192.168.10.99:4222
NANGMAN_NATS_DOCKER_NETWORK=nangman-crypto-bus

AWS_REGION=ap-northeast-2
INTEL_L1_L0_RUSTFS_ENDPOINT=https://s3.nangman.cloud
INTEL_L1_L0_RUSTFS_BUCKET=intel-crawl-app-l0
INTEL_L1_L0_RUSTFS_REGION=us-east-1
INTEL_L1_L0_RUSTFS_FORCE_PATH_STYLE=true
INTEL_L1_L0_RUSTFS_ACCESS_KEY_ID=
INTEL_L1_L0_RUSTFS_SECRET_ACCESS_KEY=
INTEL_L1_OUTPUT_S3_BUCKET=nangman-crypto-dev-intel-structuring-l1-962214
INTEL_L1_OUTPUT_S3_REGION=ap-northeast-2
INTEL_L1_MARKET_L1_BUCKET=nangman-crypto-dev-market-ingest-l1-962214
INTEL_L1_MARKET_S3_REGION=ap-northeast-2
INTEL_L1_MARKET_CONTEXT_RADIUS_WINDOWS=1
INTEL_L1_MARKET_CONTEXT_LATEST_BEFORE_LOOKBACK_MS=21600000
INTEL_L1_MARKET_CONTEXT_STALE_AFTER_MS=600000

INTEL_L1_RAW_NATS_STREAM=RAW_INTEL
INTEL_L1_RAW_NATS_SUBJECT=raw_intel_event.created
INTEL_L1_RAW_NATS_CONSUMER=intel-structuring-l1
INTEL_L1_RAW_DELIVER_POLICY=all
INTEL_L1_OUTPUT_NATS_STREAM=STRUCTURED_INTEL
INTEL_L1_STRUCTURED_PACKET_SUBJECT=structured_intel_packet.created
INTEL_L1_CONTEXT_FLAG_SUBJECT=context_flag_packet.created
INTEL_L1_HEALTH_SUBJECT=structuring_health_event.created
INTEL_L1_ENSURE_OUTPUT_STREAM=true
INTEL_L1_OUTPUT_STREAM_MAX_AGE_SECS=1209600
INTEL_L1_OUTPUT_STREAM_DUPLICATE_WINDOW_SECS=86400
INTEL_L1_RAW_ACK_WAIT_SECS=300
INTEL_L1_RAW_MAX_DELIVER=20
INTEL_L1_RAW_BATCH_SIZE=1

INTEL_L1_ENABLE_BEDROCK=false
BEDROCK_REGION=ap-northeast-2
INTEL_L1_PRIMARY_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
INTEL_L1_ESCALATION_MODEL_ID=global.anthropic.claude-sonnet-4-6
INTEL_L1_ESCALATE_IF_CONFIDENCE_BELOW=0.65
INTEL_L1_SONNET_BUDGET_RATIO=0.15
INTEL_L1_STORY_MEMBER_SCAN_LIMIT=128
