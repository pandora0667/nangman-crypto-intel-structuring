{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nangman.local/contracts/intel/intel_l1_index_pointer_v1.schema.json",
  "title": "Intel L1 Index Pointer v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "raw_event_id",
    "status",
    "manifest_key",
    "structured_packet_keys",
    "context_flag_keys",
    "finished_at_ms",
    "structuring_policy_version"
  ],
  "properties": {
    "schema_version": { "const": "intel_l1_index_pointer_v1" },
    "packet_id": { "type": "string", "minLength": 1 },
    "raw_event_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "manifest_key": { "type": "string", "minLength": 1 },
    "structured_packet_keys": { "type": "array", "items": { "type": "string" } },
    "context_flag_keys": { "type": "array", "items": { "type": "string" } },
    "finished_at_ms": { "type": "integer" },
    "structuring_policy_version": { "type": "string", "minLength": 1 }
  }
}
