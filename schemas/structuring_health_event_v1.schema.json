{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nangman.local/contracts/intel/structuring_health_event_v1.schema.json",
  "title": "Structuring Health Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "health_event_id",
    "observed_at_ms",
    "input_event_count",
    "cluster_count",
    "structured_packet_count",
    "flag_packet_count",
    "model_l0_invocations",
    "model_l1_invocations",
    "fallback_count",
    "conflict_high_count",
    "health_level",
    "reason",
    "schema_version"
  ],
  "properties": {
    "health_event_id": { "type": "string", "minLength": 1 },
    "observed_at_ms": { "type": "integer" },
    "input_event_count": { "type": "integer", "minimum": 0 },
    "cluster_count": { "type": "integer", "minimum": 0 },
    "structured_packet_count": { "type": "integer", "minimum": 0 },
    "flag_packet_count": { "type": "integer", "minimum": 0 },
    "model_l0_invocations": { "type": "integer", "minimum": 0 },
    "model_l1_invocations": { "type": "integer", "minimum": 0 },
    "fallback_count": { "type": "integer", "minimum": 0 },
    "conflict_high_count": { "type": "integer", "minimum": 0 },
    "health_level": { "type": "string", "enum": ["healthy", "degraded", "fallback_only", "blocked"] },
    "reason": { "type": ["string", "null"] },
    "schema_version": { "const": "structuring_health_event_v1" }
  }
}
