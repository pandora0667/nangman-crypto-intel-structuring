{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nangman.local/contracts/intel/intel_l1_manifest_v1.schema.json",
  "title": "Intel L1 Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "raw_event_id",
    "status",
    "started_at_ms",
    "finished_at_ms",
    "structuring_policy_version",
    "output_object_count",
    "output_objects",
    "structured_packet_count",
    "context_flag_packet_count",
    "story_cluster_count",
    "health_event_count"
  ],
  "properties": {
    "schema_version": { "const": "intel_l1_manifest_v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "raw_event_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "started_at_ms": { "type": "integer" },
    "finished_at_ms": { "type": "integer" },
    "structuring_policy_version": { "type": "string", "minLength": 1 },
    "output_object_count": { "type": "integer", "minimum": 0 },
    "output_objects": {
      "type": "array",
      "items": { "$ref": "#/$defs/output_object_ref" }
    },
    "structured_packet_count": { "type": "integer", "minimum": 0 },
    "context_flag_packet_count": { "type": "integer", "minimum": 0 },
    "story_cluster_count": { "type": "integer", "minimum": 0 },
    "health_event_count": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "output_object_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_family", "key", "record_count", "byte_count"],
      "properties": {
        "object_family": { "type": "string", "minLength": 1 },
        "key": { "type": "string", "minLength": 1 },
        "record_count": { "type": "integer", "minimum": 0 },
        "byte_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
