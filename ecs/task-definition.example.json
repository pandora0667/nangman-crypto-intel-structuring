{
  "family": "nangman-crypto-intel-structuring-app",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::791444962214:role/REPLACE_WITH_ECS_EXECUTION_ROLE",
  "taskRoleArn": "arn:aws:iam::791444962214:role/REPLACE_WITH_INTEL_L1_TASK_ROLE",
  "containerDefinitions": [
    {
      "name": "intel-structuring-app",
      "image": "REPLACE_WITH_ECR_IMAGE_URI",
      "essential": true,
      "stopTimeout": 120,
      "readonlyRootFilesystem": true,
      "linuxParameters": {
        "capabilities": {
          "drop": ["ALL"]
        }
      },
      "command": [
        "--nats-url",
        "nats://REPLACE_WITH_S2S_NATS_HOST:4222",
        "--raw-stream",
        "RAW_INTEL",
        "--raw-subject",
        "raw_intel_event.created",
        "--raw-consumer",
        "intel-structuring-l1"
      ],
      "environment": [
        { "name": "AWS_REGION", "value": "ap-northeast-2" },
        { "name": "BEDROCK_REGION", "value": "ap-northeast-2" },
        { "name": "INTEL_L1_ENABLE_BEDROCK", "value": "true" },
        { "name": "INTEL_L1_L0_RUSTFS_ENDPOINT", "value": "https://s3.nangman.cloud" },
        { "name": "INTEL_L1_L0_RUSTFS_BUCKET", "value": "intel-crawl-app-l0" },
        { "name": "INTEL_L1_L0_RUSTFS_REGION", "value": "us-east-1" },
        { "name": "INTEL_L1_L0_RUSTFS_FORCE_PATH_STYLE", "value": "true" },
        { "name": "INTEL_L1_OUTPUT_S3_BUCKET", "value": "nangman-crypto-dev-intel-structuring-l1-962214" },
        { "name": "INTEL_L1_OUTPUT_S3_REGION", "value": "ap-northeast-2" },
        { "name": "INTEL_L1_MARKET_L1_BUCKET", "value": "nangman-crypto-dev-market-ingest-l1-962214" },
        { "name": "INTEL_L1_MARKET_S3_REGION", "value": "ap-northeast-2" },
        { "name": "INTEL_L1_MARKET_CONTEXT_RADIUS_WINDOWS", "value": "1" },
        { "name": "INTEL_L1_MARKET_CONTEXT_LATEST_BEFORE_LOOKBACK_MS", "value": "21600000" },
        { "name": "INTEL_L1_MARKET_CONTEXT_STALE_AFTER_MS", "value": "600000" },
        { "name": "INTEL_L1_OUTPUT_STREAM_MAX_AGE_SECS", "value": "1209600" },
        { "name": "INTEL_L1_OUTPUT_STREAM_DUPLICATE_WINDOW_SECS", "value": "86400" },
        { "name": "INTEL_L1_RAW_ACK_WAIT_SECS", "value": "300" },
        { "name": "INTEL_L1_RAW_MAX_DELIVER", "value": "20" },
        { "name": "INTEL_L1_RAW_BATCH_SIZE", "value": "1" },
        { "name": "INTEL_L1_RAW_DELIVER_POLICY", "value": "new" },
        { "name": "INTEL_L1_PRIMARY_MODEL_ID", "value": "global.anthropic.claude-haiku-4-5-20251001-v1:0" },
        { "name": "INTEL_L1_ESCALATION_MODEL_ID", "value": "global.anthropic.claude-sonnet-4-6" },
        { "name": "INTEL_L1_ESCALATE_IF_CONFIDENCE_BELOW", "value": "0.65" },
        { "name": "INTEL_L1_SONNET_BUDGET_RATIO", "value": "0.15" }
      ],
      "secrets": [
        {
          "name": "INTEL_L1_L0_RUSTFS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:791444962214:secret:REPLACE_WITH_RUSTFS_ACCESS_KEY"
        },
        {
          "name": "INTEL_L1_L0_RUSTFS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:791444962214:secret:REPLACE_WITH_RUSTFS_SECRET_KEY"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/nangman-crypto/intel-structuring-app",
          "awslogs-region": "ap-northeast-2",
          "awslogs-create-group": "true",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
